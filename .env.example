# Copy this file to .env.local and fill in your own Figma values.
# Never commit .env.local.
FIGMA_TOKEN=your_figma_personal_access_token
FIGMA_URL=https://www.figma.com/design/FILE_KEY/FILE_NAME?node-id=0-1
# Optional overrides. Node ids can use either 0-1 or 0:1.
FIGMA_FILE_KEY=
FIGMA_NODE_ID=
FIGMA_VISUAL_THRESHOLD=95
